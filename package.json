{
	"name": "mooncraft",
	"version": "0.1.0",
	"private": true,
	"description": "Online RTS game similar to StarCraft/WarCraft",
	"author": "MoonCraft Team",
	"license": "MIT",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@react-three/postprocessing": "^3.0.4",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.2.2",
		"next": "^16.2.1",
		"postgres": "^3.4.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"three": "^0.183.2",
		"ws": "^8.20.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@types/ws": "^8.18.1",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
